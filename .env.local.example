# ============================================================================
# 모두의 솔로몬 — 환경변수 예시
# 이 파일을 .env.local 로 복사 후 값 채우기. .env.local 은 git ignore 대상.
# ============================================================================

# --- Supabase (필수) -------------------------------------------------------
# Supabase 프로젝트 → Project Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...

# --- 서버 전용 (필수) -------------------------------------------------------
# 절대 클라이언트 번들에 노출 금지 (NEXT_PUBLIC_ prefix 사용 X).
# Supabase 프로젝트 → Project Settings → API → service_role 키
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...

# Vercel Cron 인증 시크릿 — openssl rand -base64 32 로 생성
CRON_SECRET=your-random-secret-string

# --- 사이트 URL (OAuth 콜백/메타데이터 용) ----------------------------------
# 프로덕션 배포 시 Vercel 도메인으로 교체.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Play Store TWA (Google Play 배포 시) -----------------------------------
# Google Play Console → 앱 → 설정 → 앱 서명 → SHA-256 지문 (콜론 포함 형식)
PLAY_STORE_SHA256_CERT=AB:CD:EF:...
# Capacitor Android 패키지명 (capacitor.config.ts 의 appId 와 일치)
ANDROID_PACKAGE_NAME=com.solomon.app

# --- Capacitor 로컬 개발 (네이티브 앱 테스트 시) ----------------------------
# npm run cap:ios / cap:android 실행 전 설정
CAPACITOR_SERVER_URL=http://localhost:3000
